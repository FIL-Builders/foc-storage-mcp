# ============================================================================
# FOC-Storage MCP Configuration
# ============================================================================


# Wallet Configuration
# IMPORTANT: Your private key for signing transactions
# Get this from your Filecoin wallet (e.g., MetaMask, hardware wallet export)
PRIVATE_KEY=your_private_key_here
FILECOIN_NETWORK=calibration
# Source tag reported to Synapse (defaults to foc-storage-mcp)
SYNAPSE_SOURCE=foc-storage-mcp
TOTAL_STORAGE_NEEDED_GiB=1024
PERSISTENCE_PERIOD_DAYS=365
RUNOUT_NOTIFICATION_THRESHOLD_DAYS=30


# OpenAI Configuration (for Mastra agent)
OPENAI_API_KEY=""